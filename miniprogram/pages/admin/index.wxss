.setting-tabs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-bottom: 20rpx;
  padding: 8rpx;
  border: 1rpx solid #e4e9f0;
  border-radius: 12rpx;
  background: #fff;
}

.setting-tab {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  border-radius: 8rpx;
  color: #606266;
  font-weight: 700;
}

.setting-tab.active {
  color: #fff;
  background: #409eff;
}

.user-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid #e4e9f0;
  opacity: 1;
  transform: translateX(0);
  transition: opacity 0.22s ease, transform 0.22s ease;
}

.user-row.removing {
  opacity: 0;
  transform: translateX(40rpx);
}

.user-row:first-of-type {
  border-top: 0;
}

.name {
  font-size: 30rpx;
  font-weight: 800;
}

.row-main {
  flex: 1;
  min-width: 0;
}

.status {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  color: #67c23a;
  background: #f0f9eb;
  font-size: 24rpx;
}

.mini-danger {
  width: 120rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0;
  border-radius: 8rpx;
  color: #f56c6c;
  background: #fff5f5;
  font-size: 24rpx;
}

.knowledge-row {
  padding: 18rpx 0;
  border-top: 1rpx solid #e4e9f0;
}

.knowledge-row:first-of-type {
  border-top: 0;
}

.kb-q {
  margin-bottom: 8rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.knowledge-file-box {
  margin-bottom: 20rpx;
  padding: 18rpx;
  border: 1rpx dashed #c7d2df;
  border-radius: 8rpx;
  background: #f8fbff;
}

.knowledge-file-box button {
  margin-bottom: 12rpx;
}

.selected-file {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  color: #4b5563;
  font-size: 24rpx;
}

.selected-file text:first-child {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.remove-file {
  flex: 0 0 auto;
  color: #f56c6c;
}

.kb-file {
  margin-bottom: 6rpx;
  color: #409eff;
  font-size: 24rpx;
}

.success-pop {
  position: fixed;
  top: 132rpx;
  left: 50%;
  z-index: 20;
  min-width: 220rpx;
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  color: #fff;
  background: #67c23a;
  text-align: center;
  box-shadow: 0 12rpx 30rpx rgba(103, 194, 58, 0.28);
  transform: translateX(-50%);
  animation: success-pop 1.1s ease both;
}

@keyframes success-pop {
  0% {
    opacity: 0;
    transform: translate(-50%, -16rpx) scale(0.94);
  }
  18%,
  78% {
    opacity: 1;
    transform: translate(-50%, 0) scale(1);
  }
  100% {
    opacity: 0;
    transform: translate(-50%, -10rpx) scale(0.98);
  }
}
