.setting-tabs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-bottom: 20rpx;
  padding: 8rpx;
  border: 1rpx solid #e4e9f0;
  border-radius: 12rpx;
  background: #fff;
}

.setting-tab {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  border-radius: 8rpx;
  color: #606266;
  font-weight: 700;
}

.setting-tab.active {
  color: #fff;
  background: #409eff;
}

.user-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid #e4e9f0;
  opacity: 1;
  transform: translateX(0);
  transition: opacity 0.22s ease, transform 0.22s ease;
}

.user-row.removing {
  opacity: 0;
  transform: translateX(40rpx);
}

.user-row:first-of-type {
  border-top: 0;
}

.name {
  font-size: 30rpx;
  font-weight: 800;
}

.row-main {
  flex: 1;
  min-width: 0;
}

.status {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  color: #67c23a;
  background: #f0f9eb;
  font-size: 24rpx;
}

.mini-danger {
  width: 120rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0;
  border-radius: 8rpx;
  color: #f56c6c;
  background: #fff5f5;
  font-size: 24rpx;
}

.knowledge-row {
  padding: 18rpx 0;
  border-top: 1rpx solid #e4e9f0;
}

.knowledge-row:first-of-type {
  border-top: 0;
}

.kb-q {
  margin-bottom: 8rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.knowledge-file-box {
  margin-bottom: 20rpx;
  padding: 18rpx;
  border: 1rpx dashed #c7d2df;
  border-radius: 8rpx;
  background: #f8fbff;
}

.knowledge-file-box button {
  margin-bottom: 12rpx;
}

.selected-file {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  color: #4b5563;
  font-size: 24rpx;
}

.selected-file text:first-child {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.remove-file {
  flex: 0 0 auto;
  color: #f56c6c;
}

.kb-file {
  margin-bottom: 6rpx;
  color: #409eff;
  font-size: 24rpx;
}

.success-mask {
  position: fixed;
  inset: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: rgba(31, 45, 61, 0.42);
}

.success-card {
  width: 100%;
  max-width: 580rpx;
  padding: 48rpx 38rpx 36rpx;
  border-radius: 16rpx;
  background: #fff;
  text-align: center;
  box-shadow: 0 24rpx 60rpx rgba(31, 45, 61, 0.22);
  animation: success-card 0.22s ease both;
}

.success-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 104rpx;
  height: 104rpx;
  margin: 0 auto 24rpx;
  border-radius: 50%;
  color: #fff;
  background: #67c23a;
  font-size: 64rpx;
  font-weight: 800;
  box-shadow: 0 16rpx 36rpx rgba(103, 194, 58, 0.24);
}

.success-title {
  color: #1f2d3d;
  font-size: 34rpx;
  font-weight: 800;
}

.success-detail {
  margin-top: 14rpx;
  color: #7a8798;
  font-size: 25rpx;
  line-height: 1.65;
}

.success-close {
  margin-top: 30rpx;
}

@keyframes success-card {
  0% {
    opacity: 0;
    transform: translateY(18rpx) scale(0.96);
  }
  100% { opacity: 1; transform: translateY(0) scale(1); }
}
