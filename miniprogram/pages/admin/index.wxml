<view class="page">
  <view class="header">
    <text class="crumb">我的 / 系统设置</text>
    <view class="title">系统设置</view>
    <view class="subtitle">维护员工账号、角色权限、单位和小智知识库</view>
  </view>

  <view wx:if="{{successVisible}}" class="success-mask" bindtap="closeSuccess">
    <view class="success-card" catchtap="noop">
      <view class="success-icon">✓</view>
      <view class="success-title">{{successTitle}}</view>
      <view class="success-detail">{{successDetail}}</view>
      <button class="primary-btn success-close" bindtap="closeSuccess">知道了</button>
    </view>
  </view>

  <view wx:if="{{resetUserId}}" class="success-mask" bindtap="closeResetPassword">
    <view class="reset-password-card" catchtap="noop">
      <view class="section-title">重置员工密码</view>
      <view class="muted reset-summary">为 {{resetUserName}} 设置新密码，重置后该员工需要重新登录。</view>
      <view class="form-item"><text class="label">新密码</text><input password value="{{resetPassword}}" bindinput="onResetPassword" placeholder="至少6位" /></view>
      <view class="form-item"><text class="label">确认新密码</text><input password value="{{resetPasswordConfirm}}" bindinput="onResetPasswordConfirm" /></view>
      <view class="reset-actions"><button class="plain-btn" bindtap="closeResetPassword">取消</button><button class="primary-btn" loading="{{resettingPassword}}" disabled="{{resettingPassword}}" bindtap="submitResetPassword">确认重置</button></view>
    </view>
  </view>

  <view class="setting-tabs">
    <view class="setting-tab {{activeTab === 'accounts' ? 'active' : ''}}" data-tab="accounts" bindtap="switchTab">账号管理</view>
    <view class="setting-tab {{activeTab === 'knowledge' ? 'active' : ''}}" data-tab="knowledge" bindtap="switchTab">知识库</view>
  </view>

  <view wx:if="{{activeTab === 'accounts'}}">
  <form bindsubmit="submitUser">
    <view class="card">
      <view class="section-title">新建员工</view>
      <view class="form-item">
        <text class="label">员工姓名</text>
        <input name="name" value="{{userName}}" bindinput="onUserName" placeholder="例如：李销售" />
      </view>
      <view class="grid-2">
        <view class="form-item">
          <text class="label">登录账号（手机号）</text>
          <input name="account" type="number" value="{{userAccount}}" bindinput="onUserAccount" placeholder="员工手机号" />
        </view>
        <view class="form-item">
          <text class="label">初始密码</text>
          <input name="password" password value="{{userPassword}}" bindinput="onUserPassword" placeholder="例如：123456" />
        </view>
      </view>
      <view class="grid-2">
        <view class="form-item">
          <text class="label">角色</text>
          <picker range="{{roles}}" range-key="name" value="{{roleIndex}}" bindchange="onRole">
            <view class="picker-box">{{roles[roleIndex].name}}</view>
          </picker>
        </view>
        <view class="form-item">
          <text class="label">单位</text>
          <picker range="{{units}}" range-key="name" value="{{unitIndex}}" bindchange="onUnit">
            <view class="picker-box">{{unitPickerText}}</view>
          </picker>
        </view>
      </view>
      <button class="primary-btn" form-type="submit" loading="{{savingUser}}" disabled="{{savingUser}}">{{savingUser ? '开通中' : '开通账号'}}</button>
    </view>
  </form>

  <form bindsubmit="submitRole">
    <view class="card">
      <view class="section-title">角色权限</view>
      <view class="form-item">
        <text class="label">角色名称</text>
        <input name="name" placeholder="例如：大区招商主管" />
      </view>
      <view class="form-item">
        <text class="label">客户范围</text>
        <picker range="{{scopes}}" value="{{scopeIndex}}" bindchange="onScope">
          <view class="picker-box">{{scopes[scopeIndex]}}</view>
        </picker>
      </view>
      <button class="plain-btn" form-type="submit">添加角色</button>
    </view>
  </form>

  <form bindsubmit="submitUnit">
    <view class="card">
      <view class="section-title">单位管理</view>
      <view class="form-item">
        <text class="label">单位名称</text>
        <input name="name" value="{{unitName}}" bindinput="onUnitName" placeholder="例如：东部战区杭州一部" />
      </view>
      <view class="form-item">
        <text class="label">所属战区</text>
        <picker range="{{zones}}" value="{{zoneIndex}}" bindchange="onZone">
          <view class="picker-box">{{zones[zoneIndex]}}</view>
        </picker>
      </view>
      <button class="plain-btn" form-type="submit" loading="{{savingUnit}}" disabled="{{savingUnit}}">{{savingUnit ? '添加中' : '添加单位'}}</button>
    </view>
  </form>

  <view class="card">
    <view class="section-title">员工列表</view>
    <view class="user-row {{deletingUserId === item.id ? 'removing' : ''}}" wx:for="{{users}}" wx:key="id">
      <view class="row-main">
        <view class="name">{{item.name}}</view>
        <view class="muted">{{item.role}} · {{item.unit || '未填单位'}} · {{item.zone || item.region || '未分战区'}}</view>
        <view class="muted">账号：{{item.account || item.username}}</view>
      </view>
      <view wx:if="{{currentUserId !== item.id}}" class="user-row-actions">
        <button class="mini-action" data-id="{{item.id}}" bindtap="openResetPassword">重置密码</button>
        <button class="mini-danger" data-id="{{item.id}}" bindtap="deleteUser">删除</button>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">单位列表</view>
    <view class="user-row {{deletingUnitId === item.id ? 'removing' : ''}}" wx:for="{{units}}" wx:key="id">
      <view class="row-main">
        <view class="name">{{item.name}}</view>
        <view class="muted">{{item.zone}}</view>
      </view>
      <button class="mini-danger" data-id="{{item.id}}" bindtap="deleteUnit">删除</button>
    </view>
  </view>
  </view>

  <view wx:if="{{activeTab === 'knowledge'}}">
  <form bindsubmit="submitKnowledge">
    <view class="card">
      <view class="section-title">小智知识库</view>
      <view class="form-item">
        <text class="label">知识标题</text>
        <input name="question" placeholder="例如：价格异议处理" />
      </view>
      <view class="form-item">
        <text class="label">知识内容</text>
        <textarea name="answer" placeholder="可填写标准话术，也可以只上传文件"></textarea>
      </view>
      <view class="knowledge-file-box">
        <button class="plain-btn" type="button" bindtap="chooseKnowledgeFile">选择文件</button>
        <view wx:if="{{knowledgeFile}}" class="selected-file">
          <text>{{knowledgeFile.name}}</text>
          <text class="remove-file" bindtap="clearKnowledgeFile">移除</text>
        </view>
        <text wx:else class="muted">支持 TXT、MD、CSV、JSON、PDF、DOCX、XLSX</text>
      </view>
      <button class="primary-btn" form-type="submit">添加到知识库</button>
    </view>
  </form>
  <view class="card">
    <view class="section-title">知识库列表</view>
    <view class="knowledge-row" wx:for="{{knowledge}}" wx:key="id">
      <view class="kb-q">{{item.question}}</view>
      <view wx:if="{{item.fileName}}" class="kb-file">文件：{{item.fileName}}</view>
      <view class="muted">{{item.summary || item.answer || '文件已上传'}}</view>
    </view>
  </view>
  </view>
</view>
