<view class="page">
  <view class="header">
    <text class="crumb">我的 / 管理员后台</text>
    <view class="title">员工账号管理</view>
    <view class="subtitle">开通员工账号，设置登录账号、初始密码、角色和区域。</view>
  </view>

  <form bindsubmit="submitUser">
    <view class="card">
      <view class="section-title">新建员工</view>
      <view class="form-item">
        <text class="label">员工姓名</text>
        <input name="name" placeholder="例如：李销售" />
      </view>
      <view class="grid-2">
        <view class="form-item">
          <text class="label">登录账号</text>
          <input name="account" placeholder="例如：lixiaoshou" />
        </view>
        <view class="form-item">
          <text class="label">初始密码</text>
          <input name="password" password placeholder="至少6位更好记" />
        </view>
      </view>
      <view class="form-item">
        <text class="label">手机号</text>
        <input name="phone" type="number" placeholder="员工手机号，可用于登录识别" />
      </view>
      <view class="grid-2">
        <view class="form-item">
          <text class="label">角色</text>
          <picker range="{{roles}}" value="{{roleIndex}}" bindchange="onRole">
            <view class="picker-box">{{roles[roleIndex]}}</view>
          </picker>
        </view>
        <view class="form-item">
          <text class="label">区域</text>
          <input name="region" placeholder="华东 / 华南" />
        </view>
      </view>
      <view class="form-item">
        <text class="label">单位/部门</text>
        <input name="unit" placeholder="华东定制产业带 / 总部增长运营" />
      </view>
      <button class="primary-btn" form-type="submit" loading="{{saving}}" disabled="{{saving}}">开通账号</button>
    </view>
  </form>

  <view class="card">
    <view class="section-title">员工列表</view>
    <view class="user-row" wx:for="{{users}}" wx:key="id">
      <view>
        <view class="name">{{item.name}}</view>
        <view class="muted">{{item.role}} · {{item.region || item.unit}} · {{item.phone || '未填手机号'}}</view>
        <view class="muted">账号：{{item.account || item.username}}</view>
      </view>
      <text class="status">{{item.status || '启用'}}</text>
    </view>
  </view>
</view>
