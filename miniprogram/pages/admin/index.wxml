<view class="page">
  <view class="header">
    <text class="crumb">我的 / 系统设置</text>
    <view class="title">系统设置</view>
    <view class="subtitle">维护员工账号、角色权限、单位和小智知识库</view>
  </view>

  <view wx:if="{{successMessage}}" class="success-pop">{{successMessage}}</view>

  <view class="setting-tabs">
    <view class="setting-tab {{activeTab === 'accounts' ? 'active' : ''}}" data-tab="accounts" bindtap="switchTab">账号管理</view>
    <view class="setting-tab {{activeTab === 'knowledge' ? 'active' : ''}}" data-tab="knowledge" bindtap="switchTab">知识库</view>
  </view>

  <view wx:if="{{activeTab === 'accounts'}}">
  <form bindsubmit="submitUser">
    <view class="card">
      <view class="section-title">新建员工</view>
      <view class="form-item">
        <text class="label">员工姓名</text>
        <input name="name" placeholder="例如：李销售" />
      </view>
      <view class="grid-2">
        <view class="form-item">
          <text class="label">登录账号（手机号）</text>
          <input name="account" type="number" placeholder="员工手机号" />
        </view>
        <view class="form-item">
          <text class="label">初始密码</text>
          <input name="password" password placeholder="例如：123456" />
        </view>
      </view>
      <view class="grid-2">
        <view class="form-item">
          <text class="label">角色</text>
          <picker range="{{roles}}" range-key="name" value="{{roleIndex}}" bindchange="onRole">
            <view class="picker-box">{{roles[roleIndex].name}}</view>
          </picker>
        </view>
        <view class="form-item">
          <text class="label">单位</text>
          <picker range="{{units}}" range-key="name" value="{{unitIndex}}" bindchange="onUnit">
            <view class="picker-box">{{unitPickerText}}</view>
          </picker>
        </view>
      </view>
      <button class="primary-btn" form-type="submit" loading="{{saving}}" disabled="{{saving}}">开通账号</button>
    </view>
  </form>

  <form bindsubmit="submitRole">
    <view class="card">
      <view class="section-title">角色权限</view>
      <view class="form-item">
        <text class="label">角色名称</text>
        <input name="name" placeholder="例如：大区招商主管" />
      </view>
      <view class="form-item">
        <text class="label">客户范围</text>
        <picker range="{{scopes}}" value="{{scopeIndex}}" bindchange="onScope">
          <view class="picker-box">{{scopes[scopeIndex]}}</view>
        </picker>
      </view>
      <button class="plain-btn" form-type="submit">添加角色</button>
    </view>
  </form>

  <form bindsubmit="submitUnit">
    <view class="card">
      <view class="section-title">单位管理</view>
      <view class="form-item">
        <text class="label">单位名称</text>
        <input name="name" placeholder="例如：东部战区杭州一部" />
      </view>
      <view class="form-item">
        <text class="label">所属战区</text>
        <picker range="{{zones}}" value="{{zoneIndex}}" bindchange="onZone">
          <view class="picker-box">{{zones[zoneIndex]}}</view>
        </picker>
      </view>
      <button class="plain-btn" form-type="submit">添加单位</button>
    </view>
  </form>

  <view class="card">
    <view class="section-title">员工列表</view>
    <view class="user-row {{deletingUserId === item.id ? 'removing' : ''}}" wx:for="{{users}}" wx:key="id">
      <view class="row-main">
        <view class="name">{{item.name}}</view>
        <view class="muted">{{item.role}} · {{item.unit || '未填单位'}} · {{item.zone || item.region || '未分战区'}}</view>
        <view class="muted">账号：{{item.account || item.username}}</view>
      </view>
      <button class="mini-danger" data-id="{{item.id}}" bindtap="deleteUser">删除</button>
    </view>
  </view>

  <view class="card">
    <view class="section-title">单位列表</view>
    <view class="user-row {{deletingUnitId === item.id ? 'removing' : ''}}" wx:for="{{units}}" wx:key="id">
      <view class="row-main">
        <view class="name">{{item.name}}</view>
        <view class="muted">{{item.zone}}</view>
      </view>
      <button class="mini-danger" data-id="{{item.id}}" bindtap="deleteUnit">删除</button>
    </view>
  </view>
  </view>

  <view wx:if="{{activeTab === 'knowledge'}}">
  <form bindsubmit="submitKnowledge">
    <view class="card">
      <view class="section-title">小智知识库</view>
      <view class="form-item">
        <text class="label">常见问题</text>
        <input name="question" placeholder="例如：价格太高怎么办？" />
      </view>
      <view class="form-item">
        <text class="label">标准话术</text>
        <textarea name="answer" placeholder="填写给销售使用的标准应答"></textarea>
      </view>
      <button class="plain-btn" form-type="submit">添加知识</button>
    </view>
  </form>
  <view class="card">
    <view class="section-title">知识库列表</view>
    <view class="knowledge-row" wx:for="{{knowledge}}" wx:key="id">
      <view class="kb-q">{{item.question}}</view>
      <view class="muted">{{item.answer}}</view>
    </view>
  </view>
  </view>
</view>
