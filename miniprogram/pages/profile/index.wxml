<view class="page">
  <view class="header">
    <text class="crumb">首页 / 我的</text>
    <view class="title">我的账号</view>
    <view class="subtitle">当前登录员工：{{currentUser.name}}</view>
  </view>

  <view class="card">
    <view class="section-title">账号信息</view>
    <view class="current-user">
      <view class="avatar">{{currentUser.name ? currentUser.name.slice(0, 1) : '智'}}</view>
      <view>
        <view class="name">{{currentUser.name}}</view>
        <view class="muted">{{currentUser.role}} · {{currentUser.region || currentUser.unit}}</view>
        <view class="muted account">账号：{{currentUser.account || currentUser.username || currentUser.phone}}</view>
      </view>
    </view>
  </view>

  <view class="card" wx:if="{{canAdmin}}">
    <view class="section-title">系统设置</view>
    <view class="muted line">管理员可维护员工账号、角色权限、单位和小智知识库。</view>
    <button class="primary-btn admin-btn" bindtap="goAdmin">进入系统设置</button>
  </view>

  <view class="card">
    <view class="section-title">账号安全</view>
    <view class="muted line">密码修改后，当前账号在其他设备上的旧登录会立即失效。</view>
    <button class="plain-btn password-toggle" bindtap="togglePasswordForm">{{showPasswordForm ? '收起修改密码' : '修改密码'}}</button>
    <view wx:if="{{showPasswordForm}}" class="password-form">
      <view class="form-item"><text class="label">原密码</text><input password value="{{currentPassword}}" bindinput="onCurrentPassword" /></view>
      <view class="form-item"><text class="label">新密码</text><input password value="{{newPassword}}" bindinput="onNewPassword" placeholder="至少6位" /></view>
      <view class="form-item"><text class="label">确认新密码</text><input password value="{{confirmPassword}}" bindinput="onConfirmPassword" /></view>
      <button class="primary-btn" loading="{{changingPassword}}" disabled="{{changingPassword}}" bindtap="changePassword">确认修改</button>
    </view>
    <button class="danger-btn logout-btn" bindtap="logout">退出登录</button>
  </view>
</view>
