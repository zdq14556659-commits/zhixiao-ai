.current-user {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #fff;
  background: #409eff;
  font-size: 36rpx;
  font-weight: 900;
}

.name {
  font-size: 32rpx;
  font-weight: 800;
}

.account {
  margin-top: 6rpx;
}

.line {
  margin-top: 12rpx;
  line-height: 1.6;
}

.admin-btn {
  margin-top: 18rpx;
}

.logout-btn {
  margin-top: 18rpx;
}
