<view class="page">
  <view class="header">
    <text class="crumb">首页 / 经营看板</text>
    <view class="title">智销经营看板</view>
    <view class="subtitle">{{scopeName}}</view>
  </view>

  <view class="card dashboard-filter">
    <view class="filter-row">
      <picker mode="date" fields="month" value="{{month}}" bindchange="onMonth"><view class="picker-box">{{month}}</view></picker>
      <picker range="{{scopeNames}}" value="{{scopeIndex}}" bindchange="onScope"><view class="picker-box">{{scopeNames[scopeIndex] || '当前范围'}}</view></picker>
    </view>
    <view class="filter-row">
      <picker mode="date" value="{{startDate}}" bindchange="onStartDate"><view class="picker-box">{{startDate}}</view></picker>
      <picker mode="date" value="{{endDate}}" bindchange="onEndDate"><view class="picker-box">{{endDate}}</view></picker>
    </view>
  </view>

  <view wx:if="{{loading}}" class="card loading">经营数据加载中...</view>

  <view wx:else>
    <view class="metrics">
      <view class="metric-card {{item.drilldown ? 'clickable' : ''}}" wx:for="{{metrics}}" wx:key="key" data-drilldown="{{item.drilldown}}" bindtap="openMetric">
        <text>{{item.label}}</text>
        <view class="metric-value">{{item.value}}</view>
        <view class="muted metric-hint">{{item.hint}}</view>
      </view>
    </view>

    <view class="card">
      <view class="section-title">本期销售漏斗</view>
      <view class="funnel-row" wx:for="{{funnel}}" wx:key="stage">
        <text class="funnel-stage">{{item.stage}}</text>
        <view class="funnel-data"><text class="strong">{{item.count}}家</text><text>{{item.stage === '成交' ? '最终结果' : '转化 ' + item.conversionRate + '%'}}</text></view>
        <view class="funnel-data"><text class="strong">{{item.averageStayDays}}天</text><text>平均停留</text></view>
        <view class="funnel-data warning"><text class="strong">{{item.overdue}}</text><text>超期</text></view>
      </view>
    </view>

    <view class="card">
      <view class="section-title">今日行动中心</view>
      <view class="action-grid">
        <view class="action-item {{item.count ? 'active' : ''}}" wx:for="{{actions}}" wx:key="key" data-key="{{item.key}}" bindtap="openAction">
          <text>{{item.label}}</text><text class="strong">{{item.count}}</text>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="section-title">{{rankingTitle}}</view>
      <view class="ranking-head"><text>排名 / 销售</text><text>进款</text><text>成交</text><text>完成率</text></view>
      <view class="ranking-row" wx:for="{{ranking}}" wx:key="userId">
        <text><text class="rank-number">{{index + 1}}</text> {{item.name}}</text><text>{{item.revenueText}}</text><text>{{item.deals}}家</text><text>{{item.completionRate}}%</text>
      </view>
      <view wx:if="{{!ranking.length}}" class="empty">暂无排名数据</view>
    </view>

    <view class="card">
      <view class="section-title">小智经营分析</view>
      <view class="insight" wx:for="{{insights}}" wx:key="title">
        <text class="insight-title">{{item.title}}</text>
        <text class="insight-text">{{item.detail}}</text>
      </view>
    </view>
  </view>
</view>
