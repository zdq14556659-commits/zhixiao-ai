.metrics {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-bottom: 20rpx;
}

.metric-card {
  min-height: 180rpx;
  padding: 24rpx;
  border: 1rpx solid #e4e9f0;
  border-radius: 12rpx;
  background: #fff;
}

.metric-card text {
  color: #7a8798;
  font-size: 26rpx;
}

.metric-value {
  margin-top: 12rpx;
  font-size: 42rpx;
  font-weight: 900;
}

.progress {
  height: 10rpx;
  margin-top: 20rpx;
  border-radius: 999rpx;
  background: #edf2f7;
  overflow: hidden;
}

.progress view {
  height: 100%;
  border-radius: inherit;
  background: #67c23a;
}

.problem {
  padding: 20rpx 0;
  border-top: 1rpx solid #e4e9f0;
}

.problem:first-of-type {
  border-top: 0;
}

.problem-name {
  font-weight: 800;
}

.severity {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  color: #fff;
  font-size: 24rpx;
}

.severity.danger {
  background: #f56c6c;
}

.severity.warn {
  background: #e6a23c;
}

.problem-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 8rpx;
  margin-top: 14rpx;
  color: #7a8798;
  font-size: 24rpx;
}

.advice {
  margin-top: 14rpx;
  line-height: 1.6;
}

.alert {
  padding: 18rpx;
  border-left: 6rpx solid #409eff;
  border-radius: 8rpx;
  background: #fbfdff;
  margin-top: 14rpx;
}

.alert-title {
  display: block;
  font-weight: 800;
}

.alert-text {
  display: block;
  margin-top: 8rpx;
  color: #7a8798;
  line-height: 1.5;
}
