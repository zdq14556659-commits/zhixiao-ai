<view class="page">
  <view class="xiaozhi-hero">
    <view class="xiaozhi-icon">智</view>
    <view>
      <view class="title">小智</view>
      <view class="subtitle">智销AI销售跟进助手 · 从知识库检索并生成成交策略</view>
    </view>
  </view>

  <view class="card">
    <view class="form-item">
      <text class="label">客户问题</text>
      <textarea value="{{question}}" bindinput="onQuestion" placeholder="客户说：设计图能不能直接拆单到开料？"></textarea>
    </view>
    <button class="primary-btn" bindtap="recommend">让小智生成策略</button>
  </view>

  <view class="card" wx:if="{{result}}">
    <view class="section-title">小智建议</view>
    <view class="source">来源：{{result.source === 'deepseek' ? 'DeepSeek + 知识库' : '知识库本地策略'}}</view>
    <view class="answer">{{result.answer}}</view>
    <view wx:if="{{result.matched && result.matched.length}}" class="muted">命中知识：{{result.matched[0].question}}</view>
  </view>
</view>
