.xiaozhi-hero {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.xiaozhi-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 82rpx;
  height: 82rpx;
  border-radius: 18rpx;
  color: #fff;
  background: #409eff;
  font-size: 38rpx;
  font-weight: 800;
}

.advice-grid { display: grid; gap: 14rpx; margin-bottom: 20rpx; }
.advice-card { padding: 22rpx; border: 1rpx solid #dbe7f3; border-radius: 12rpx; background: #fff; line-height: 1.65; }
.advice-card text { display: block; margin-bottom: 8rpx; color: #1f2d3d; font-weight: 800; }
.draft-card textarea { margin-bottom: 16rpx; background: #f8fbff; }
.citation { padding: 16rpx 0; border-top: 1rpx solid #e4e9f0; }
.citation:first-of-type { border-top: 0; }
.citation text { font-weight: 700; }
.citation .muted { margin-top: 6rpx; line-height: 1.5; font-size: 24rpx; }
