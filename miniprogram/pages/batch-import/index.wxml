<view class="page">
  <view class="header">
    <text class="crumb">客户管理 / 批量导入</text>
    <view class="title">{{targetPublicPool ? '批量导入公海' : '批量导入客户'}}</view>
    <view class="subtitle">{{targetPublicPool ? '公海导入必须包含工厂名称、有效主联系人手机号和完整地址' : '每行一个客户：客户名称,手机号,渠道来源,客户地址,现用软件,预计金额（元）'}}</view>
  </view>

  <form bindsubmit="submitImport">
    <view class="card">
      <view wx:if="{{!targetPublicPool}}" class="grid-2">
        <view class="form-item">
          <text class="label">导入阶段</text>
          <picker range="{{stages}}" value="{{stageIndex}}" bindchange="onStage">
            <view class="picker-box">{{stages[stageIndex]}}</view>
          </picker>
        </view>
        <view class="form-item">
          <text class="label">默认负责人</text>
          <picker range="{{owners}}" value="{{ownerIndex}}" bindchange="onOwner">
            <view class="picker-box">{{owners[ownerIndex]}}</view>
          </picker>
        </view>
      </view>
      <view class="form-item">
        <text class="label">默认渠道来源</text>
        <picker range="{{channelSources}}" value="{{channelIndex}}" bindchange="onChannel">
          <view class="picker-box">{{channelSources[channelIndex]}}</view>
        </picker>
      </view>
      <view class="form-item">
        <text class="label">客户数据</text>
        <textarea name="rows" placeholder="佛山柜体门板厂,13900139000,地推,广东省佛山市,酷家乐+手工报价,260000&#10;成都整装定制工厂,13600000001,企查查,四川省成都市,自研ERP+Excel,320000"></textarea>
      </view>
      <view class="form-hint">也可以上传 CSV/TXT 文件，字段请和 Web 下载样表一致。</view>
      <view class="actions">
        <button class="plain-btn" type="button" bindtap="chooseFile" disabled="{{importing}}">上传文件</button>
        <button class="primary-btn" form-type="submit" loading="{{importing}}" disabled="{{importing}}">粘贴导入</button>
      </view>
      <view wx:if="{{fileName}}" class="file-name">已选择：{{fileName}}</view>
    </view>
  </form>

  <view wx:if="{{importResult}}" class="card import-result-card">
    <view class="section-title">导入结果</view>
    <view class="result-grid">
      <view><text>总行数</text><strong>{{importResult.total}}</strong></view>
      <view class="success"><text>成功</text><strong>{{importResult.imported}}</strong></view>
      <view class="warning"><text>重复</text><strong>{{importResult.duplicates}}</strong></view>
      <view class="danger"><text>失败</text><strong>{{importResult.failed}}</strong></view>
      <view wx:if="{{importResult.pendingLocation}}" class="warning"><text>待定位</text><strong>{{importResult.pendingLocation}}</strong></view>
    </view>
    <view wx:if="{{importResult.duplicates}}" class="duplicate-notice">重复手机号对应的客户已经存在，本次已自动跳过，不会覆盖原客户。</view>
    <view wx:if="{{targetPublicPool && geocodeProgressText}}" class="geocode-progress">
      <text>{{geocodeProgressText}}</text>
      <button class="plain-btn" bindtap="refreshGeocodeProgress">刷新定位进度</button>
    </view>
    <scroll-view wx:if="{{importResult.skipped.length || importResult.failures.length}}" class="result-scroll" scroll-y>
      <view wx:if="{{importResult.skipped.length}}" class="result-list">
        <view class="result-list-title">重复明细</view>
        <view class="result-row" wx:for="{{importResult.skipped}}" wx:key="rowNumber">
          <text>第{{item.rowNumber}}行 · {{item.name || '未命名客户'}}</text>
          <text>{{item.phone || '手机号未填写'}} · {{item.reason}}</text>
        </view>
      </view>
      <view wx:if="{{importResult.failures.length}}" class="result-list">
        <view class="result-list-title">失败明细</view>
        <view class="result-row" wx:for="{{importResult.failures}}" wx:key="rowNumber">
          <text>第{{item.rowNumber}}行 · {{item.name || '未命名客户'}}</text>
          <text>{{item.phone || '手机号未填写'}} · {{item.reason}}</text>
        </view>
      </view>
    </scroll-view>
    <button wx:if="{{importResult.reportUrl}}" class="plain-btn report-btn" bindtap="copyReport">复制完整明细下载地址</button>
    <button class="primary-btn report-btn" bindtap="backToCustomers">返回客户列表</button>
  </view>
</view>
