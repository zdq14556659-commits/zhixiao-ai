<view class="page">
  <view class="header">
    <text class="crumb">客户管理 / 批量导入</text>
    <view class="title">批量导入客户</view>
    <view class="subtitle">每行一个客户：客户名称,手机号,渠道来源,客户地址,现用软件,预计金额</view>
  </view>

  <form bindsubmit="submitImport">
    <view class="card">
      <view class="grid-2">
        <view class="form-item">
          <text class="label">导入阶段</text>
          <picker range="{{stages}}" value="{{stageIndex}}" bindchange="onStage">
            <view class="picker-box">{{stages[stageIndex]}}</view>
          </picker>
        </view>
        <view class="form-item">
          <text class="label">默认负责人</text>
          <picker range="{{owners}}" value="{{ownerIndex}}" bindchange="onOwner">
            <view class="picker-box">{{owners[ownerIndex]}}</view>
          </picker>
        </view>
      </view>
      <view class="form-item">
        <text class="label">默认渠道来源</text>
        <picker range="{{channelSources}}" value="{{channelIndex}}" bindchange="onChannel">
          <view class="picker-box">{{channelSources[channelIndex]}}</view>
        </picker>
      </view>
      <view class="form-item">
        <text class="label">客户数据</text>
        <textarea name="rows" placeholder="佛山柜体门板厂,13900139000,地推,广东省佛山市,酷家乐+手工报价,26&#10;成都整装定制工厂,13600000001,企查查,四川省成都市,自研ERP+Excel,32"></textarea>
      </view>
      <view class="form-hint">也可以上传 CSV/TXT 文件，字段请和 Web 下载样表一致。</view>
      <view class="actions">
        <button class="plain-btn" type="button" bindtap="chooseFile">上传文件</button>
        <button class="primary-btn" form-type="submit">粘贴导入</button>
      </view>
      <view wx:if="{{fileName}}" class="file-name">已选择：{{fileName}}</view>
    </view>
  </form>
</view>
