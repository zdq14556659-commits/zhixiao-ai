<view class="page">
  <view class="header">
    <text class="crumb">首页 / 客户管理</text>
    <view class="title">{{currentStage}}管理</view>
  </view>

  <scroll-view class="stage-tabs" scroll-x>
    <view class="stage-tab {{currentStage === item.name ? 'active' : ''}}" wx:for="{{stageTabs}}" wx:key="name" data-stage="{{item.name}}" bindtap="switchStage">
      {{item.name}} <text>{{item.count}}</text>
    </view>
  </scroll-view>

  <view class="card filter-card {{filtersOpen ? 'open' : ''}}">
    <view class="filter-toggle" bindtap="toggleFilters">
      <view>
        <view class="filter-title">搜索筛选</view>
        <text class="muted">{{hasActiveFilters ? '已设置筛选条件' : '点击展开搜索客户'}}</text>
      </view>
      <text class="filter-arrow">{{filtersOpen ? '⌃' : '⌄'}}</text>
    </view>
    <view wx:if="{{filtersOpen}}" class="filter-body">
      <view class="form-item">
        <text class="label">关键词</text>
        <input value="{{keyword}}" placeholder="客户名称 / 手机号" bindinput="onKeyword" />
      </view>
      <view class="filter-grid">
        <view class="form-item">
          <text class="label">{{stageTimeLabel}}开始</text>
          <picker mode="date" value="{{stageStartDate}}" bindchange="onStageStartDate">
            <view class="picker-box">{{stageStartDate || '请选择'}}</view>
          </picker>
        </view>
        <view class="form-item">
          <text class="label">{{stageTimeLabel}}结束</text>
          <picker mode="date" value="{{stageEndDate}}" bindchange="onStageEndDate">
            <view class="picker-box">{{stageEndDate || '请选择'}}</view>
          </picker>
        </view>
      </view>
      <view class="filter-grid">
        <view class="form-item">
          <text class="label">城市</text>
          <picker range="{{cities}}" value="{{cityIndex}}" bindchange="onCity"><view class="picker-box">{{cities[cityIndex]}}</view></picker>
        </view>
        <view class="form-item"></view>
      </view>
      <view class="filter-grid">
        <view class="form-item">
          <text class="label">最新跟进开始</text>
          <picker mode="date" value="{{lastStartDate}}" bindchange="onLastStartDate">
            <view class="picker-box">{{lastStartDate || '请选择'}}</view>
          </picker>
        </view>
        <view class="form-item">
          <text class="label">最新跟进结束</text>
          <picker mode="date" value="{{lastEndDate}}" bindchange="onLastEndDate">
            <view class="picker-box">{{lastEndDate || '请选择'}}</view>
          </picker>
        </view>
      </view>
      <view class="filter-grid">
        <view class="form-item">
          <text class="label">下次跟进开始</text>
          <picker mode="date" value="{{nextStartDate}}" bindchange="onNextStartDate">
            <view class="picker-box">{{nextStartDate || '请选择'}}</view>
          </picker>
        </view>
        <view class="form-item">
          <text class="label">下次跟进结束</text>
          <picker mode="date" value="{{nextEndDate}}" bindchange="onNextEndDate">
            <view class="picker-box">{{nextEndDate || '请选择'}}</view>
          </picker>
        </view>
      </view>
      <view class="filter-grid">
        <view class="form-item">
          <text class="label">渠道来源</text>
          <picker range="{{channelSources}}" value="{{channelIndex}}" bindchange="onChannel">
            <view class="picker-box">{{channelSources[channelIndex]}}</view>
          </picker>
        </view>
        <view wx:if="{{canFilterOwner}}" class="form-item">
          <text class="label">负责人</text>
          <picker range="{{owners}}" value="{{ownerIndex}}" bindchange="onOwner">
            <view class="picker-box">{{owners[ownerIndex]}}</view>
          </picker>
        </view>
        <view wx:else class="form-item"></view>
      </view>
      <view class="filter-grid">
        <view class="form-item">
          <text class="label">区域</text>
          <picker range="{{regions}}" value="{{regionIndex}}" bindchange="onRegion">
            <view class="picker-box">{{regions[regionIndex]}}</view>
          </picker>
        </view>
        <view class="form-item">
          <text class="label">跟进状态</text>
          <picker range="{{followStatuses}}" value="{{followStatusIndex}}" bindchange="onFollowStatus">
            <view class="picker-box">{{followStatuses[followStatusIndex]}}</view>
          </picker>
        </view>
      </view>
      <view class="filter-actions">
        <button class="plain-btn" bindtap="resetFilters">重置</button>
        <button class="primary-btn" bindtap="applyFilters">查询</button>
      </view>
    </view>
  </view>

  <view class="list-head">
    <text class="muted list-count">{{currentStage === '公海' ? '公海共 ' + publicPoolTotal : '共 ' + currentStageTotal}} 个客户</text>
    <view wx:if="{{currentStage !== '公海' || canImportPublic}}" class="head-actions">
      <button class="plain-btn mini-btn" bindtap="goBatchImport">{{currentStage === '公海' ? '导入公海' : '批量导入'}}</button>
      <button wx:if="{{currentStage !== '公海'}}" class="primary-btn mini-btn" bindtap="goAdd">单个添加</button>
    </view>
  </view>

  <view class="pool-state" wx:if="{{currentStage !== '公海' && customerBoardLoading && !paged.length}}">正在加载最新客户数据...</view>
  <view class="pool-state pool-error" wx:elif="{{currentStage !== '公海' && customerBoardError}}">
    <text>{{customerBoardError}}</text>
    <button class="plain-btn" bindtap="loadCustomerBoard">重新加载</button>
  </view>

  <view class="customer-strip" wx:for="{{paged}}" wx:key="id" data-id="{{item.id}}" bindtap="editCustomer">
    <view class="strip-main">
      <view class="strip-top">
        <view class="customer-name ellipsis">{{item.name}}</view>
        <view class="strip-tags">
          <text wx:if="{{item.ownershipLabel}}" class="ownership-tag {{item.ownershipStatus}}">{{item.ownershipLabel}}</text>
          <text class="tag">{{item.stage}}</text>
        </view>
      </view>
      <view class="strip-line ellipsis">{{item.productName || '待确认产品'}} · {{item.city || '待识别'}} · {{item.channelLabel}}</view>
      <view wx:if="{{!item.isPublicPool}}" class="strip-line ellipsis">{{item.phone}} · {{item.followPerson || item.owner}}</view>
      <view wx:else class="strip-line ellipsis">手机号与联系人认领后可见</view>
      <view class="strip-line ellipsis">{{stageTimeLabel}}：{{item.stageDate || '未记录'}}</view>
      <view wx:if="{{!item.isPublicPool}}" class="strip-line ellipsis">{{item.primarySoftware}} · 下次：{{item.nextFollow || '未设置'}}</view>
      <view wx:if="{{!item.isPublicPool}}" class="strip-note ellipsis">{{item.lastNote || '暂无跟进记录'}}</view>
      <view wx:else class="strip-note ellipsis">进入公海：{{item.publicPoolAt || '时间未记录'}}，认领后可查看历史跟进</view>
      <view wx:if="{{item.firstPhoto}}" class="photo-chip" data-id="{{item.id}}" data-src="{{item.firstPhoto}}" catchtap="previewCustomerPhoto">
        <image src="{{item.firstPhoto}}" mode="aspectFill"></image>
        <text>{{item.photoCount}}张现场图</text>
      </view>
    </view>
    <view wx:if="{{!item.isPublicPool}}" class="strip-actions {{item.canAssign ? 'has-assign' : ''}}">
      <button class="plain-btn" data-phone="{{item.phone}}" catchtap="callCustomer">拨打</button>
      <button class="plain-btn" data-id="{{item.id}}" catchtap="goFollow">跟进</button>
      <button class="primary-btn" data-id="{{item.id}}" catchtap="advanceCustomer">{{item.stage === '成交' ? '新增机会' : '推进'}}</button>
      <button wx:if="{{item.canAssign}}" class="assign-btn" data-id="{{item.id}}" catchtap="assignCustomer">分配</button>
    </view>
    <view wx:else class="strip-actions pool-actions">
      <button wx:if="{{item.canClaim}}" class="primary-btn" data-id="{{item.id}}" catchtap="claimCustomer">认领后跟进</button>
      <button wx:elif="{{item.canAssign}}" class="assign-btn" data-id="{{item.id}}" catchtap="assignCustomer">分配给销售</button>
      <text wx:else class="pool-hint">{{item.poolHint}}</text>
    </view>
  </view>

  <view class="pool-state" wx:if="{{currentStage === '公海' && publicPoolLoading}}">正在加载最新公海客户...</view>
  <view class="pool-state pool-error" wx:elif="{{currentStage === '公海' && publicPoolError}}">
    <text>{{publicPoolError}}</text>
    <button class="plain-btn" bindtap="retryPublicPool">重新加载</button>
  </view>
  <view class="pool-state" wx:elif="{{currentStage === '公海' && publicPoolLoaded && publicPoolTotal === 0}}">当前公海暂无客户</view>
  <view class="pool-state" wx:elif="{{currentStage === '公海' && publicPoolFilteredOut}}">
    <text>公海共{{publicPoolTotal}}条，当前筛选后0条</text>
    <button class="plain-btn" bindtap="resetFilters">一键重置筛选</button>
  </view>
  <view class="pool-state" wx:elif="{{currentStage !== '公海' && !customerBoardLoading && !customerBoardError && filteredOut}}">
    <text>当前阶段共{{currentStageTotal}}条，筛选后0条</text>
    <button class="plain-btn" bindtap="resetFilters">一键重置筛选</button>
  </view>
  <view class="empty" wx:elif="{{currentStage !== '公海' && !customerBoardLoading && !customerBoardError && currentStageTotal === 0}}">当前阶段暂无客户</view>
  <view class="page-tools" wx:if="{{filtered.length}}">
    <picker range="{{pageSizes}}" value="{{pageSizeIndex}}" bindchange="onPageSize">
      <view class="page-size">每页 {{pageSize}} 条⌄</view>
    </picker>
    <text>共 {{filtered.length}} 条</text>
  </view>
  <view class="pager" wx:if="{{filtered.length > pageSize}}">
    <button class="plain-btn" bindtap="prevPage" disabled="{{page <= 1}}">上一页</button>
    <text>{{page}} / {{totalPages}}</text>
    <button class="plain-btn" bindtap="nextPage" disabled="{{page >= totalPages}}">下一页</button>
  </view>

  <view wx:if="{{advanceOpen}}" class="modal-mask" catchtouchmove="true">
    <view class="modal-card">
      <view class="modal-title">推进为{{advanceTargetStage}}</view>
      <view class="muted">{{advanceItem.name}} · {{advanceItem.productName}}</view>
      <view wx:if="{{advanceTargetStage === '商机'}}" class="form-item"><text class="label">有效演示日期 <text class="required-mark">*</text></text><picker mode="date" value="{{advanceDemoAt}}" bindchange="onAdvanceDemoAt"><view class="picker-box">{{advanceDemoAt || '请选择'}}</view></picker></view>
      <block wx:if="{{advanceTargetStage === '成交'}}">
        <view class="form-item"><text class="label">合同金额（元） <text class="required-mark">*</text></text><input type="digit" value="{{advanceContractAmount}}" data-field="advanceContractAmount" bindinput="onAdvanceField" /></view>
        <view class="form-item"><text class="label">实际进款（元，可后补）</text><input type="digit" value="{{advancePaymentAmount}}" data-field="advancePaymentAmount" bindinput="onAdvanceField" /></view>
        <view class="form-item"><text class="label">进款日期</text><picker mode="date" value="{{advancePaymentDate}}" bindchange="onAdvancePaymentDate"><view class="picker-box">{{advancePaymentDate || '未进款'}}</view></picker></view>
      </block>
      <view class="form-item"><text class="label">本次跟进内容 <text class="required-mark">*</text></text><textarea value="{{advanceNote}}" data-field="advanceNote" bindinput="onAdvanceField"></textarea></view>
      <view class="form-item"><text class="label">下次跟进 <text class="required-mark">*</text></text><picker mode="date" value="{{advanceNextFollow}}" bindchange="onAdvanceNextFollow"><view class="picker-box">{{advanceNextFollow || '未设置'}}</view></picker></view>
      <view class="modal-actions"><button class="plain-btn" bindtap="closeAdvance">取消</button><button class="primary-btn" bindtap="submitAdvanceForm">确认推进</button></view>
    </view>
  </view>

  <view wx:if="{{newOpportunityOpen}}" class="modal-mask" catchtouchmove="true">
    <view class="modal-card">
      <view class="modal-title">新增销售机会</view>
      <view class="muted">成交机会保留，新产品从线索重新轮转</view>
      <view class="form-item"><text class="label">意向产品 <text class="required-mark">*</text></text><picker range="{{products}}" range-key="name" value="{{productIndex}}" bindchange="onProduct"><view class="picker-box">{{products[productIndex].name || '请选择'}}</view></picker></view>
      <view class="form-item"><text class="label">首次跟进备注 <text class="required-mark">*</text></text><textarea value="{{newOpportunityNote}}" data-field="newOpportunityNote" bindinput="onNewOpportunityField"></textarea></view>
      <view class="form-item"><text class="label">下次跟进 <text class="required-mark">*</text></text><picker mode="date" value="{{newOpportunityNextFollow}}" bindchange="onNewOpportunityNextFollow"><view class="picker-box">{{newOpportunityNextFollow || '请选择'}}</view></picker></view>
      <view class="modal-actions"><button class="plain-btn" bindtap="closeNewOpportunity">取消</button><button class="primary-btn" bindtap="submitNewOpportunity">创建线索</button></view>
    </view>
  </view>
</view>
