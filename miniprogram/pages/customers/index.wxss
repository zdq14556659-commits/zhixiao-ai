.stage-tabs {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 20rpx;
  border: 1rpx solid #e4e9f0;
  border-radius: 12rpx;
  background: #fff;
  overflow: hidden;
}

.stage-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 25%;
  min-width: 150rpx;
  height: 88rpx;
  color: #606266;
  border-right: 1rpx solid #e4e9f0;
}

.stage-tab.active {
  color: #409eff;
  font-weight: 800;
  box-shadow: inset 0 -6rpx 0 #409eff;
}

.stage-tab text {
  margin-left: 8rpx;
  color: #7a8798;
  font-size: 24rpx;
}

.filter-card {
  padding: 0;
  overflow: hidden;
}

.filter-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx 24rpx;
}

.filter-title {
  margin-bottom: 6rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.filter-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  border-radius: 999rpx;
  color: #409eff;
  background: #ecf5ff;
  font-size: 34rpx;
  font-weight: 800;
}

.filter-body {
  padding: 0 24rpx 24rpx;
  border-top: 1rpx solid #edf1f6;
}

.filter-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 18rpx;
}

.filter-actions {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 16rpx;
  margin-top: 4rpx;
}

.list-head {
  display: block;
  margin: 20rpx 0;
}

.list-count {
  display: block;
  margin-bottom: 14rpx;
}

.head-actions {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 12rpx;
}

.mini-btn {
  min-width: 140rpx;
  min-height: 64rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
}

.customer-strip {
  display: block;
  margin-bottom: 14rpx;
  padding: 20rpx;
  border: 1rpx solid #e4e9f0;
  border-radius: 12rpx;
  background: #fff;
}

.customer-strip:active {
  background: #f8fbff;
  transform: scale(0.995);
}

.strip-main {
  min-width: 0;
}

.strip-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  min-width: 0;
}

.strip-top .tag {
  flex: 0 0 auto;
}

.customer-name {
  margin-bottom: 8rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.strip-line,
.strip-note {
  margin-top: 6rpx;
  color: #5f6f80;
  font-size: 25rpx;
}

.strip-note {
  color: #8a96a8;
}

.photo-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  max-width: 260rpx;
  margin-top: 10rpx;
  padding: 6rpx 10rpx;
  border-radius: 999rpx;
  color: #409eff;
  background: #ecf5ff;
  font-size: 23rpx;
}

.photo-chip image {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
}

.strip-actions {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8rpx;
  width: 100%;
  margin-top: 14rpx;
}

.strip-actions.has-assign {
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.strip-actions button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 52rpx;
  min-height: 52rpx;
  line-height: 1.2;
  min-width: 0;
  padding: 0;
  font-size: 23rpx;
}

.assign-btn {
  color: #e6a23c;
  background: #fdf6ec;
}

.assign-btn::after {
  border: 0;
}

.pager {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 110rpx minmax(0, 1fr);
  align-items: center;
  gap: 12rpx;
  margin: 24rpx 0;
  color: #7a8798;
  text-align: center;
}

.pager button {
  min-height: 60rpx;
  font-size: 24rpx;
}

.empty {
  padding: 80rpx 0;
  color: #7a8798;
  text-align: center;
}
