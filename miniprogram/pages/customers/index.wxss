.page {
  width: 100%;
  overflow-x: hidden;
}

.stage-tabs {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 20rpx;
  border: 1rpx solid #e4e9f0;
  border-radius: 12rpx;
  background: #fff;
  overflow: hidden;
}

.stage-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 25%;
  min-width: 150rpx;
  height: 88rpx;
  color: #606266;
  border-right: 1rpx solid #e4e9f0;
}

.stage-tab.active {
  color: #409eff;
  font-weight: 800;
  box-shadow: inset 0 -6rpx 0 #409eff;
}

.stage-tab text {
  margin-left: 8rpx;
  color: #7a8798;
  font-size: 24rpx;
}

.filter-card {
  padding: 0;
  overflow: hidden;
}

.filter-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx 24rpx;
}

.filter-title {
  margin-bottom: 6rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.filter-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  border-radius: 999rpx;
  color: #409eff;
  background: #ecf5ff;
  font-size: 34rpx;
  font-weight: 800;
}

.filter-body {
  padding: 0 24rpx 24rpx;
  border-top: 1rpx solid #edf1f6;
}

.filter-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 18rpx;
}

.filter-actions {
  display: flex;
  width: 100%;
  min-width: 0;
  gap: 16rpx;
  margin-top: 4rpx;
  overflow: hidden;
}

.filter-actions > button {
  flex: 1 1 0;
  width: 0;
  min-width: 0;
  max-width: 100%;
  padding: 0 12rpx;
}

.list-head {
  display: block;
  margin: 20rpx 0;
}

.list-count {
  display: block;
  margin-bottom: 14rpx;
}

.head-actions {
  display: flex;
  width: 100%;
  min-width: 0;
  gap: 12rpx;
  overflow: hidden;
}

.mini-btn {
  flex: 1 1 0;
  width: 0;
  min-width: 0;
  max-width: 100%;
  min-height: 64rpx;
  padding: 0 12rpx;
  font-size: 26rpx;
}

.customer-strip {
  display: block;
  margin-bottom: 14rpx;
  padding: 20rpx;
  border: 1rpx solid #e4e9f0;
  border-radius: 12rpx;
  background: #fff;
}

.customer-strip:active {
  background: #f8fbff;
  transform: scale(0.995);
}

.strip-main {
  min-width: 0;
}

.strip-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  min-width: 0;
}

.strip-top .tag {
  flex: 0 0 auto;
}

.strip-tags {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  gap: 8rpx;
}

.ownership-tag {
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  color: #2879b8;
  background: #eaf5ff;
  font-size: 20rpx;
}

.ownership-tag.claimable {
  color: #ad6800;
  background: #fff7e6;
}

.ownership-tag.public_pool {
  color: #9a5b00;
  background: #fff3d6;
}

.customer-name {
  margin-bottom: 8rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.strip-line,
.strip-note {
  margin-top: 6rpx;
  color: #5f6f80;
  font-size: 25rpx;
}

.strip-note {
  color: #8a96a8;
}

.photo-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  max-width: 260rpx;
  margin-top: 10rpx;
  padding: 6rpx 10rpx;
  border-radius: 999rpx;
  color: #409eff;
  background: #ecf5ff;
  font-size: 23rpx;
}

.photo-chip image {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
}

.strip-actions {
  display: flex;
  gap: 8rpx;
  width: 100%;
  min-width: 0;
  margin-top: 14rpx;
  overflow: hidden;
}

.strip-actions button {
  display: flex;
  flex: 1 1 0;
  align-items: center;
  justify-content: center;
  width: 0;
  max-width: 100%;
  height: 52rpx;
  min-height: 52rpx;
  line-height: 1.2;
  min-width: 0;
  padding: 0;
  font-size: 23rpx;
}

.assign-btn {
  color: #e6a23c;
  background: #fdf6ec;
}

.assign-btn::after {
  border: 0;
}

.pool-actions button {
  width: 100%;
}

.invalid-actions .pool-hint {
  flex: 1 1 auto;
  justify-content: flex-start;
  width: auto;
}

.invalid-actions .danger-btn {
  flex: 0 0 140rpx;
  width: 140rpx;
  color: #d92d20;
  background: #fff;
}

.invalid-actions .danger-btn::after {
  border-color: #f2b8b5;
}

.pool-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 52rpx;
  color: #8a96a8;
  font-size: 24rpx;
}

.page-tools {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 22rpx 0 10rpx;
  color: #7a8798;
  font-size: 24rpx;
}

.page-size {
  min-width: 180rpx;
  padding: 12rpx 18rpx;
  border: 1rpx solid #dcdfe6;
  border-radius: 8rpx;
  color: #4b5563;
  background: #fff;
}

.page-input-line,
.jump-pager {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #7a8798;
}

.page-input-line input,
.jump-pager input {
  width: 104rpx;
  min-height: 58rpx;
  padding: 0 12rpx;
  border: 1rpx solid #dcdfe6;
  border-radius: 8rpx;
  background: #fff;
  color: #1f2d3d;
}

.pager {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 110rpx minmax(0, 1fr);
  align-items: center;
  gap: 12rpx;
  margin: 24rpx 0;
  color: #7a8798;
  text-align: center;
}

.pager button {
  min-height: 60rpx;
  font-size: 24rpx;
}

.jump-pager {
  justify-content: center;
  margin: 0 0 24rpx;
}

.empty {
  padding: 80rpx 0;
  color: #7a8798;
  text-align: center;
}

.pool-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 72rpx 24rpx;
  color: #65758b;
  text-align: center;
}

.pool-state button {
  width: auto;
  min-width: 220rpx;
  margin: 0;
}

.pool-error {
  color: #c45656;
}

.required-mark {
  color: #e5484d;
  font-weight: 700;
}

.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx;
  background: rgba(15, 23, 42, 0.5);
  box-sizing: border-box;
}

.modal-card {
  width: 100%;
  max-height: 82vh;
  overflow-y: auto;
  padding: 30rpx;
  border-radius: 12rpx;
  background: #fff;
  box-sizing: border-box;
}

.modal-title {
  margin-bottom: 8rpx;
  font-size: 36rpx;
  font-weight: 700;
}

.modal-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 24rpx;
}

.modal-actions button {
  width: 100%;
  margin: 0;
  box-sizing: border-box;
}
