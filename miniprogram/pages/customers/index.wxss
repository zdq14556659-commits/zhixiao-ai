.stage-tabs {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 20rpx;
  border: 1rpx solid #e4e9f0;
  border-radius: 12rpx;
  background: #fff;
  overflow: hidden;
}

.stage-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 25%;
  min-width: 150rpx;
  height: 88rpx;
  color: #606266;
  border-right: 1rpx solid #e4e9f0;
}

.stage-tab.active {
  color: #409eff;
  font-weight: 800;
  box-shadow: inset 0 -6rpx 0 #409eff;
}

.stage-tab text {
  margin-left: 8rpx;
  color: #7a8798;
  font-size: 24rpx;
}

.filter-card {
  padding: 0;
  overflow: hidden;
}

.filter-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx 24rpx;
}

.filter-title {
  margin-bottom: 6rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.filter-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  border-radius: 999rpx;
  color: #409eff;
  background: #ecf5ff;
  font-size: 34rpx;
  font-weight: 800;
}

.filter-body {
  padding: 0 24rpx 24rpx;
  border-top: 1rpx solid #edf1f6;
}

.filter-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 18rpx;
}

.filter-actions {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 16rpx;
  margin-top: 4rpx;
}

.list-head {
  display: block;
  margin: 20rpx 0;
}

.list-count {
  display: block;
  margin-bottom: 14rpx;
}

.head-actions {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 12rpx;
}

.mini-btn {
  min-width: 140rpx;
  min-height: 64rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
}

.customer-card {
  margin-bottom: 18rpx;
  padding: 22rpx;
  border: 1rpx solid #e4e9f0;
  border-radius: 12rpx;
  background: #fff;
}

.customer-card:active {
  background: #f8fbff;
  transform: scale(0.995);
}

.customer-card .row {
  align-items: flex-start;
}

.customer-name {
  margin-bottom: 8rpx;
  font-size: 32rpx;
  font-weight: 800;
}

.info {
  margin-top: 14rpx;
  color: #3f4a59;
}

.note {
  margin: 14rpx 0;
  padding: 16rpx;
  border-radius: 8rpx;
  color: #606266;
  background: #f7f9fb;
  line-height: 1.55;
}

.actions {
  grid-template-columns: 1fr 1fr 1fr;
}

.customer-actions {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  width: 100%;
}

.customer-actions button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  line-height: 1.2;
  min-width: 0;
  padding: 0 8rpx;
  font-size: 27rpx;
}

.empty {
  padding: 80rpx 0;
  color: #7a8798;
  text-align: center;
}
