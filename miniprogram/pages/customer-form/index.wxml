<view class="page">
  <view class="header">
    <text class="crumb">客户管理 / {{editingId ? '编辑客户' : '单个添加'}}</text>
    <view class="title">{{editingId ? '编辑客户' : '新增客户'}}</view>
  </view>

  <form bindsubmit="submitForm">
    <view class="card">
      <view class="form-item">
        <text class="label">客户名称</text>
        <input class="{{identityLocked ? 'locked-input' : ''}}" name="name" value="{{form.name}}" disabled="{{identityLocked}}" placeholder="例：佛山柜体门板厂" />
        <text wx:if="{{identityLocked}}" class="lock-note">已有客户名称仅管理员可修改</text>
      </view>
      <view class="form-item">
        <text class="label">手机号</text>
        <input class="{{identityLocked ? 'locked-input' : ''}}" name="phone" type="number" value="{{form.phone}}" disabled="{{identityLocked}}" placeholder="客户手机号" />
        <text wx:if="{{identityLocked}}" class="lock-note">已有客户手机号仅管理员可修改</text>
      </view>
      <view class="form-item">
        <text class="label">渠道来源</text>
        <picker range="{{channelSources}}" value="{{channelIndex}}" bindchange="onChannel">
          <view class="picker-box">{{channelSources[channelIndex]}}</view>
        </picker>
      </view>
      <view class="grid-2">
        <view class="form-item">
          <text class="label">阶段</text>
          <picker range="{{stages}}" value="{{stageIndex}}" bindchange="onStage">
            <view class="picker-box">{{stages[stageIndex]}}</view>
          </picker>
        </view>
        <view class="form-item">
          <text class="label">负责人</text>
          <picker range="{{owners}}" value="{{ownerIndex}}" bindchange="onOwner">
            <view class="picker-box">{{owners[ownerIndex]}}</view>
          </picker>
        </view>
      </view>
      <view class="grid-2">
        <view class="form-item">
          <text class="label">区域</text>
          <input name="region" value="{{form.region}}" placeholder="华东 / 华南" />
        </view>
        <view class="form-item">
          <text class="label">预计金额（万）</text>
          <input name="amount" type="digit" value="{{form.amount}}" placeholder="15" />
        </view>
      </view>
      <view class="form-item">
        <text class="label">现用软件</text>
        <input name="software" value="{{form.software}}" placeholder="酷家乐 + Excel排产" />
      </view>
      <view class="form-item">
        <text class="label">客户地址</text>
        <input name="address" value="{{form.address}}" placeholder="客户工厂地址" />
      </view>
      <view class="form-item">
        <text class="label">跟进记录</text>
        <textarea name="note" placeholder="填写本次新的沟通内容，历史记录不会被覆盖"></textarea>
      </view>
      <view class="form-item">
        <text class="label">下次跟进</text>
        <picker mode="date" value="{{nextFollow}}" bindchange="onNextFollow">
          <view class="picker-box">{{nextFollow}}</view>
        </picker>
      </view>
      <button class="primary-btn" form-type="submit">{{editingId ? '保存修改' : '保存客户'}}</button>
    </view>
  </form>
</view>
