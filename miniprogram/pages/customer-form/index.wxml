<view class="page">
  <view class="header">
    <text class="crumb">客户管理 / 单个添加</text>
    <view class="title">新增客户</view>
  </view>

  <form bindsubmit="submitForm">
    <view class="card">
      <view class="form-item">
        <text class="label">客户名称</text>
        <input name="name" placeholder="例：佛山柜体门板厂" />
      </view>
      <view class="form-item">
        <text class="label">手机号</text>
        <input name="phone" type="number" placeholder="客户手机号" />
      </view>
      <view class="form-item">
        <text class="label">渠道来源</text>
        <input name="channelSource" placeholder="地推 / 官方资源 / 转介绍 / 展会" />
      </view>
      <view class="grid-2">
        <view class="form-item">
          <text class="label">阶段</text>
          <picker range="{{stages}}" value="{{stageIndex}}" bindchange="onStage">
            <view class="picker-box">{{stages[stageIndex]}}</view>
          </picker>
        </view>
        <view class="form-item">
          <text class="label">负责人</text>
          <picker range="{{owners}}" value="{{ownerIndex}}" bindchange="onOwner">
            <view class="picker-box">{{owners[ownerIndex]}}</view>
          </picker>
        </view>
      </view>
      <view class="grid-2">
        <view class="form-item">
          <text class="label">区域</text>
          <input name="region" placeholder="华东 / 华南" />
        </view>
        <view class="form-item">
          <text class="label">预计金额（万）</text>
          <input name="amount" type="digit" placeholder="15" />
        </view>
      </view>
      <view class="form-item">
        <text class="label">现用软件</text>
        <input name="software" placeholder="酷家乐 + Excel排产" />
      </view>
      <view class="form-item">
        <text class="label">客户地址</text>
        <input name="address" placeholder="客户工厂地址" />
      </view>
      <view class="form-item">
        <text class="label">跟进记录</text>
        <textarea name="note" placeholder="填写本次沟通内容"></textarea>
      </view>
      <view class="form-item">
        <text class="label">下次跟进</text>
        <picker mode="date" value="{{nextFollow}}" bindchange="onNextFollow">
          <view class="picker-box">{{nextFollow}}</view>
        </picker>
      </view>
      <button class="primary-btn" form-type="submit">保存客户</button>
    </view>
  </form>
</view>
