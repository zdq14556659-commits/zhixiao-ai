<view class="page">
  <view class="header">
    <text class="crumb">客户管理 / {{editingId ? '编辑客户' : '单个添加'}}</text>
    <view class="title">{{editingId ? '编辑客户' : '新增客户'}}</view>
  </view>

  <form bindsubmit="submitForm">
    <view class="card">
      <view class="form-item">
        <text class="label">客户名称 <text class="required-mark">*</text></text>
        <input class="{{identityLocked ? 'locked-input' : ''}}" name="name" value="{{form.name}}" disabled="{{identityLocked}}" placeholder="例：佛山柜体门板厂" />
      </view>
      <view class="form-item">
        <text class="label">主联系人手机号 <text class="required-mark">*</text></text>
        <input class="{{identityLocked ? 'locked-input' : ''}}" name="phone" type="number" value="{{form.phone}}" disabled="{{identityLocked}}" placeholder="客户手机号" />
      </view>
      <view class="form-item">
        <text class="label">渠道来源</text>
        <picker range="{{channelSources}}" value="{{channelIndex}}" bindchange="onChannel" disabled="{{metadataLocked}}">
          <view class="picker-box {{metadataLocked ? 'locked-input' : ''}}">{{channelSources[channelIndex]}}</view>
        </picker>
      </view>
      <view class="form-item">
        <text class="label">录入人</text>
        <input class="{{metadataLocked ? 'locked-input' : ''}}" name="createdBy" value="{{form.createdBy || ''}}" disabled="{{metadataLocked}}" placeholder="录入员工姓名" />
      </view>
      <view class="grid-2">
        <view class="form-item"><text class="label">意向产品</text><picker range="{{products}}" range-key="name" value="{{productIndex}}" bindchange="onProduct"><view class="picker-box">{{products[productIndex].name || '请选择'}}</view></picker></view>
        <view class="form-item"><text class="label">城市</text><input name="city" value="{{form.city}}" placeholder="可从地址自动识别" /></view>
      </view>
      <view class="grid-2">
        <view class="form-item">
          <text class="label">阶段</text>
          <picker range="{{stages}}" value="{{stageIndex}}" bindchange="onStage">
            <view class="picker-box">{{stages[stageIndex]}}</view>
          </picker>
        </view>
        <view class="form-item">
          <text class="label">负责人</text>
          <picker range="{{owners}}" value="{{ownerIndex}}" bindchange="onOwner">
            <view class="picker-box">{{owners[ownerIndex]}}</view>
          </picker>
        </view>
      </view>
      <view class="grid-2">
        <view class="form-item">
          <text class="label">区域</text>
          <input name="region" value="{{form.region}}" placeholder="华东 / 华南" />
        </view>
        <view class="form-item">
          <text class="label">预计金额（元）</text>
          <input name="amount" type="digit" value="{{form.amount}}" placeholder="150000" />
        </view>
      </view>
      <view class="section-divider row">
        <text>联系人档案</text>
        <button class="plain-btn section-add" type="button" bindtap="addContact">添加联系人</button>
      </view>
      <view class="repeat-card" wx:for="{{contacts}}" wx:key="index">
        <view class="row repeat-head">
          <text>{{item.isPrimary ? '主联系人' : '联系人 ' + (index + 1)}}</text>
          <view class="repeat-actions">
            <button wx:if="{{item.phone || (item.isPrimary && form.phone)}}" class="link-btn" type="button" data-phone="{{item.isPrimary ? form.phone : item.phone}}" bindtap="callContact">拨打</button>
            <button wx:if="{{!item.isPrimary && !identityLocked}}" class="link-btn" type="button" data-index="{{index}}" bindtap="setPrimaryContact">设为主联系人</button>
            <button wx:if="{{!item.isPrimary}}" class="link-btn danger-text" type="button" data-index="{{index}}" bindtap="removeContact">删除</button>
          </view>
        </view>
        <view class="grid-2">
          <view class="form-item"><text class="label">姓名</text><input value="{{item.name}}" data-index="{{index}}" data-field="name" bindinput="updateContact" placeholder="联系人姓名" /></view>
          <view class="form-item"><text class="label">手机号</text><input value="{{item.isPrimary ? form.phone : item.phone}}" disabled="{{item.isPrimary}}" type="number" data-index="{{index}}" data-field="phone" bindinput="updateContact" placeholder="联系人手机号" /></view>
        </view>
        <view class="grid-2">
          <view class="form-item"><text class="label">职位</text><input value="{{item.position}}" data-index="{{index}}" data-field="position" bindinput="updateContact" placeholder="老板 / 设计主管" /></view>
          <view class="form-item"><text class="label">微信</text><input value="{{item.wechat}}" data-index="{{index}}" data-field="wechat" bindinput="updateContact" placeholder="微信号" /></view>
        </view>
        <view class="form-item"><text class="label">决策角色</text><input value="{{item.decisionRole}}" data-index="{{index}}" data-field="decisionRole" bindinput="updateContact" placeholder="决策人 / 使用人 / 财务" /></view>
        <view class="form-item"><text class="label">备注</text><input value="{{item.note}}" data-index="{{index}}" data-field="note" bindinput="updateContact" placeholder="沟通偏好、关系情况等" /></view>
      </view>

      <view class="section-divider row">
        <text>竞品档案</text>
        <button class="plain-btn section-add" type="button" bindtap="addCompetitorProfile">添加竞品</button>
      </view>
      <view class="repeat-card" wx:for="{{competitorProfiles}}" wx:key="index">
        <view class="row repeat-head">
          <text>{{index === 0 ? '当前使用软件' : '其他竞品'}}</text>
          <view class="repeat-actions">
            <button class="link-btn" type="button" data-index="{{index}}" bindtap="toggleCompetitorDetails">{{item.expanded ? '收起详情' : '补充详情'}}</button>
            <button wx:if="{{index > 0}}" class="link-btn danger-text" type="button" data-index="{{index}}" bindtap="removeCompetitorProfile">删除</button>
          </view>
        </view>
        <view class="form-item"><text class="label">品牌</text><picker range="{{competitorNames}}" data-index="{{index}}" bindchange="onCompetitorBrand"><view class="picker-box">{{item.brand || '请选择'}}</view></picker></view>
        <block wx:if="{{item.expanded}}">
        <view class="grid-2">
          <view class="form-item"><text class="label">产品版本</text><input value="{{item.version}}" data-index="{{index}}" data-field="version" bindinput="updateCompetitor" placeholder="版本/模块" /></view>
          <view class="form-item"><text class="label">价格</text><input value="{{item.price}}" data-index="{{index}}" data-field="price" bindinput="updateCompetitor" placeholder="年费/买断价" /></view>
        </view>
        <view class="grid-2">
          <view class="form-item"><text class="label">到期时间</text><input value="{{item.expiresAt}}" data-index="{{index}}" data-field="expiresAt" bindinput="updateCompetitor" placeholder="YYYY-MM-DD" /></view>
          <view class="form-item"><text class="label">满意度</text><input value="{{item.satisfaction}}" data-index="{{index}}" data-field="satisfaction" bindinput="updateCompetitor" placeholder="满意 / 一般 / 不满意" /></view>
        </view>
        <view class="form-item"><text class="label">切换障碍</text><input value="{{item.switchingBarrier}}" data-index="{{index}}" data-field="switchingBarrier" bindinput="updateCompetitor" placeholder="数据迁移、员工习惯、合同未到期等" /></view>
        <view class="form-item"><text class="label">备注</text><input value="{{item.note}}" data-index="{{index}}" data-field="note" bindinput="updateCompetitor" /></view>
        </block>
      </view>
      <view class="section-divider">商机与成交信息</view>
      <view class="grid-2">
        <view class="form-item">
          <text class="label">有效演示时间</text>
          <picker mode="date" value="{{demoAt}}" bindchange="onDemoAt">
            <view class="picker-box">{{demoAt || '未完成演示'}}</view>
          </picker>
        </view>
        <view class="form-item">
          <text class="label">预计成交日期</text>
          <picker mode="date" value="{{expectedDealDate}}" bindchange="onExpectedDealDate">
            <view class="picker-box">{{expectedDealDate || '请选择'}}</view>
          </picker>
        </view>
      </view>
      <view class="grid-2">
        <view class="form-item">
          <text class="label">报价金额（元）</text>
          <input name="quoteAmount" type="digit" value="{{form.quoteAmount}}" placeholder="0" />
        </view>
        <view class="form-item">
          <text class="label">合同金额（元）</text>
          <input name="contractAmount" type="digit" value="{{form.contractAmount}}" placeholder="成交时必填" />
        </view>
      </view>
      <view class="grid-2">
        <view class="form-item">
          <text class="label">实际进款（元）</text>
          <input name="paymentAmount" type="digit" value="{{form.paymentAmount}}" placeholder="0" />
        </view>
        <view class="form-item">
          <text class="label">进款日期</text>
          <picker mode="date" value="{{paymentDate}}" bindchange="onPaymentDate">
            <view class="picker-box">{{paymentDate || '待进款'}}</view>
          </picker>
        </view>
      </view>
      <view class="form-item">
        <text class="label">进款业绩归属人</text>
        <picker range="{{paymentOwnerNames}}" value="{{paymentOwnerIndex}}" bindchange="onPaymentOwner">
          <view class="picker-box">{{paymentOwnerNames[paymentOwnerIndex] || '请选择'}}</view>
        </picker>
      </view>
      <view class="form-item">
        <text class="label">未成交原因</text>
        <input name="lossReason" value="{{form.lossReason}}" placeholder="如：预算、决策、竞品、暂缓上线" />
      </view>
      <view class="form-item">
        <text class="label">客户地址</text>
        <input name="address" value="{{form.address}}" placeholder="客户工厂地址" />
      </view>
      <view class="form-item">
        <text class="label">跟进记录</text>
        <textarea name="note" placeholder="填写本次新的沟通内容，历史记录不会被覆盖"></textarea>
      </view>
      <view class="form-item">
        <text class="label">下次跟进</text>
        <picker mode="date" value="{{nextFollow}}" bindchange="onNextFollow">
          <view class="picker-box">{{nextFollow}}</view>
        </picker>
      </view>
      <button wx:if="{{editingId}}" class="plain-btn ai-customer-btn" type="button" bindtap="openCustomerAi">让小智分析该客户</button>
      <button wx:if="{{editingId}}" class="plain-btn archive-customer-btn" type="button" bindtap="archiveCustomer">标记为无效或倒闭</button>
      <button class="primary-btn" form-type="submit">{{editingId ? '保存修改' : '保存客户'}}</button>
    </view>
  </form>
</view>
