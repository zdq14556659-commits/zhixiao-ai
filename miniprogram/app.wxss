page {
  background: #eef1f5;
  color: #22262d;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
}

view,
text,
button,
input,
textarea,
picker {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
}

.header {
  margin-bottom: 24rpx;
}

.crumb {
  color: #7a8798;
  font-size: 26rpx;
}

.title {
  margin-top: 10rpx;
  color: #22262d;
  font-size: 42rpx;
  font-weight: 800;
}

.subtitle {
  margin-top: 8rpx;
  color: #7a8798;
  font-size: 26rpx;
}

.card {
  margin-bottom: 20rpx;
  padding: 24rpx;
  border: 1rpx solid #e4e9f0;
  border-radius: 12rpx;
  background: #fff;
}

.section-title {
  margin-bottom: 18rpx;
  font-size: 32rpx;
  font-weight: 800;
}

.muted {
  color: #7a8798;
}

.primary-btn,
.plain-btn,
.danger-btn {
  min-height: 72rpx;
  margin: 0;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.primary-btn {
  color: #fff;
  background: #409eff;
}

.plain-btn {
  color: #22262d;
  background: #fff;
  border: 1rpx solid #dcdfe6;
}

.danger-btn {
  color: #fff;
  background: #f56c6c;
}

.grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.form-item {
  margin-bottom: 18rpx;
}

.label {
  display: block;
  margin-bottom: 8rpx;
  color: #7a8798;
  font-size: 26rpx;
}

input,
textarea,
.picker-box {
  width: 100%;
  min-height: 72rpx;
  padding: 16rpx 18rpx;
  border: 1rpx solid #dcdfe6;
  border-radius: 8rpx;
  background: #fff;
}

textarea {
  min-height: 180rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  min-height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  color: #409eff;
  background: #ecf5ff;
  font-size: 24rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}
