[Unit]
Description=Zhixiao AI CRM
After=network.target

[Service]
Type=simple
User=zhixiao
Group=zhixiao
WorkingDirectory=/opt/zhixiao-ai/current
EnvironmentFile=/etc/zhixiao-ai.env
Environment=NODE_OPTIONS=--max-old-space-size=1024
ExecStart=/usr/bin/node /opt/zhixiao-ai/current/backend/server.js
Restart=always
RestartSec=5
MemoryAccounting=true
MemoryHigh=1G
MemoryMax=1536M
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
